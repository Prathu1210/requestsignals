# Copy to .env.local and fill in real values. Do NOT commit .env.local.

# --- MongoDB ---
# Connection string from your MongoDB Atlas free (M0) cluster, e.g.:
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
# Database name (defaults to "linkedin_leads" if unset).
MONGODB_DB=linkedin_leads

# Admin key required by pages/api/add-lead.js (sent as x-admin-key header).
ADMIN_KEY=
NEXT_PUBLIC_ADMIN_KEY=

# --- Lead scraping pipeline (scripts/scrape-and-filter.mjs) ---

# Google Custom Search JSON API. Create a key at:
#   https://developers.google.com/custom-search/v1/introduction
# and a search engine (cx) at https://programmablesearchengine.google.com/
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=

# OpenRouter API key (free tier, no cost) used to run the classifier model
# (nvidia/nemotron-3-ultra-550b-a55b:free). Get one at:
#   https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Base URL the script POSTs qualified leads to (no trailing slash needed).
# Local: http://localhost:3000   Production: https://your-deployment.example.com
SITE_URL=

# --- Optional tuning (scripts/scrape-and-filter.mjs) ---
# Delay in ms between classification calls (default 2000).
# CLASSIFY_DELAY_MS=2000
# Results requested per Google search query, max 10 (default 10).
# RESULTS_PER_QUERY=10
# Reject posts older than this many days, based on the date parsed out of
# the search snippet (default 14).
# MAX_POST_AGE_DAYS=14
